{
  "name": "architect-studio",
  "version": "0.1.0",
  "private": true,
  "description": "Architect Studio - a simulation-driven system architecture studio",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace apps/desktop",
    "build": "npm run build --workspace apps/desktop",
    "tauri": "npm run tauri --workspace apps/desktop",
    "tauri:dev": "npm run tauri --workspace apps/desktop -- dev",
    "tauri:build": "npm run tauri --workspace apps/desktop -- build",
    "ai:dev": "cd services/ai && python3 -m uvicorn app.main:app --reload --port 8008",
    "ai:build": "cd services/ai && python3 build_sidecar.py"
  }
}
